---
import Card from "../components/Card.astro";
import Layout from '../layouts/Layout.astro';
import {IProduct} from "../types";

const response = await fetch(`${import.meta.env.API_URL}/products`)
const products: IProduct[] = (await(response.json())).data
---

<Layout title="Products">
    {products.map(product => <Card  title={product.attributes.name} body={product.attributes.description} link={product.attributes.price}/>)}
</Layout>
