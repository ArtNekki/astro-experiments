---
import Card from "../components/Card.astro";
import Layout from '../layouts/Layout.astro';
import type {IProduct} from "../types";

const response = await fetch(`${import.meta.env.API_URL}/products`)
const products = ((await(response.json())).data) as IProduct[]
---

<Layout title="Products">
    {products.map(product => <Card  title={product.attributes.name} body={product.attributes.description} price={product.attributes.price}/>)}
</Layout>
